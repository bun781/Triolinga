{
  "name": "habitz-language-learning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build && cp -R public .next/standalone/public && cp -R .next/static .next/standalone/.next/static && mkdir -p src-tauri/next-standalone && find src-tauri/next-standalone -mindepth 1 ! -name .gitkeep -exec rm -rf {} + && cp -R .next/standalone/. src-tauri/next-standalone",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "drizzle-orm": "^0.33.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "postgres": "^3.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
