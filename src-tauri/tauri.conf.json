{
  "productName": "Fydor",
  "version": "0.1.1",
  "identifier": "com.fydor.fydor",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Fydor",
        "url": "/lessons/manage",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/icon.ico"
    ],
    "targets": ["dmg"]
  }
}
