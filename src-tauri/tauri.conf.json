{
  "productName": "Fydor",
  "version": "0.1.0",
  "identifier": "com.fydor.fydor",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "frontend-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fydor",
        "url": "/",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "resources": {
      "next-standalone/": ".next/standalone/"
    }
  }
}
